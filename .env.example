# ─── App ───────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────
DATABASE_URL="postgresql://user:password@localhost:5432/teamflow?schema=public"

# ─── NextAuth.js v5 ────────────────────
AUTH_SECRET=your-auth-secret-here           # Generate: npx auth secret
AUTH_URL=http://localhost:3000              # Optional in v5 (auto-detected)

# ─── Google OAuth ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── GitHub OAuth ──────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Razorpay ──────────────────────────
RAZORPAY_KEY_ID=rzp_test_...               # Razorpay key ID from dashboard
RAZORPAY_KEY_SECRET=...                     # Razorpay key secret
RAZORPAY_WEBHOOK_SECRET=...                 # Webhook secret for signature verification
RAZORPAY_STARTER_PLAN_ID=plan_...           # Razorpay plan ID for Starter tier
RAZORPAY_PRO_PLAN_ID=plan_...               # Razorpay plan ID for Pro tier

# ─── SMTP (Email) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@teamflow.app
